{
  "type": "module",
  "scripts": {
    "dev": "tsx --watch --env-file .env src/index.ts",
    "start": "node dist/src/index.js",
    "build": "tsc",
    "deploy": "npm run build && npm run migrate",
    "generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
